{
  "name": "ax-next",
  "version": "0.0.0",
  "private": true,
  "description": "AX v2 — plugin-based personal AI agent (greenfield rewrite)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "test": "pnpm -r run test && pnpm test:eslint-rules && pnpm test:scripts",
    "test:eslint-rules": "vitest run --root eslint-rules",
    "test:scripts": "vitest run --root scripts",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "uuid@<14.0.0": ">=14.0.0",
      "@anthropic-ai/sdk@<0.91.1": ">=0.91.1",
      "ip-address@<10.1.1": ">=10.1.1",
      "hono@<4.12.25": ">=4.12.25",
      "fast-uri@<3.1.1": ">=3.1.1",
      "protobufjs@<7.6.3": ">=7.6.3",
      "@protobufjs/utf8@<1.1.1": ">=1.1.1",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "tmp@<0.2.7": ">=0.2.7",
      "assistant-cloud@<0.1.30": ">=0.1.30",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "js-yaml@<4.2.0": ">=4.2.0",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0"
    }
  }
}
