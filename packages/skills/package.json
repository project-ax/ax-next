{
  "name": "@ax/skills",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ax/core": "workspace:*",
    "@ax/skills-parser": "workspace:*",
    "js-yaml": "^4.1.0",
    "kysely": "0.28.17",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ax/agents": "workspace:*",
    "@ax/chat-orchestrator": "workspace:*",
    "@ax/database-postgres": "workspace:*",
    "@ax/test-harness": "workspace:*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "pg": "8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
