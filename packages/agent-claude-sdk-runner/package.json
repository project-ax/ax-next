{
  "name": "@ax/agent-claude-sdk-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "bin": {
    "ax-claude-sdk-runner": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "postbuild": "chmod +x dist/main.js && cp src/proxy-bootstrap.cjs dist/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "@ax/credential-proxy-bridge": "workspace:*",
    "@ax/ipc-protocol": "workspace:*",
    "undici": "^6.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
