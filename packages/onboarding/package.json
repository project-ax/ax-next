{
  "name": "@ax/onboarding",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "dist-spa"],
  "scripts": {
    "build": "tsc --build && pnpm run build:spa",
    "build:spa": "vite build --config src/spa/vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ax/core": "workspace:*",
    "kysely": "0.28.16"
  },
  "devDependencies": {
    "@ax/agents": "workspace:*",
    "@ax/auth-oidc": "workspace:*",
    "@ax/credentials": "workspace:*",
    "@ax/credentials-store-db": "workspace:*",
    "@ax/database-postgres": "workspace:*",
    "@ax/http-server": "workspace:*",
    "@ax/storage-postgres": "workspace:*",
    "@ax/test-harness": "workspace:*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "pg": "8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  }
}
