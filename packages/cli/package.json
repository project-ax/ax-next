{
  "name": "@ax/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ax-next": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "postbuild": "chmod +x dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ax/core": "workspace:*",
    "@ax/http-server": "workspace:*",
    "@ax/storage-sqlite": "workspace:*",
    "@ax/storage-postgres": "workspace:*",
    "@ax/audit-log": "workspace:*",
    "@ax/agents": "workspace:*",
    "@ax/auth-better": "workspace:*",
    "@ax/credential-proxy": "workspace:*",
    "@ax/credentials": "workspace:*",
    "@ax/credentials-store-db": "workspace:*",
    "@ax/credentials-anthropic-oauth": "workspace:*",
    "@ax/database-postgres": "workspace:*",
    "@ax/onboarding": "workspace:*",
    "@ax/sandbox-subprocess": "workspace:*",
    "@ax/session-inmemory": "workspace:*",
    "@ax/ipc-server": "workspace:*",
    "@ax/chat-orchestrator": "workspace:*",
    "@ax/agent-claude-sdk-runner": "workspace:*",
    "@ax/mcp-client": "workspace:*",
    "@ax/llm-anthropic": "workspace:*",
    "@ax/memory-strata": "workspace:*",
    "@ax/preset-k8s": "workspace:*",
    "@ax/test-harness": "workspace:*",
    "@ax/validator-skill": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "kysely": "0.28.16",
    "pg": "8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
