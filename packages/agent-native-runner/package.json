{
  "name": "@ax/agent-native-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./turn-loop": {
      "types": "./dist/turn-loop.d.ts",
      "default": "./dist/turn-loop.js"
    }
  },
  "bin": {
    "ax-agent-native-runner": "./dist/main.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "postbuild": "chmod +x dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ax/ipc-protocol": "workspace:*",
    "@ax/agent-runner-core": "workspace:*",
    "@ax/tool-bash-impl": "workspace:*",
    "@ax/tool-file-io-impl": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
